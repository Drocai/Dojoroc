# --- Supabase (optional) ---
# The app ships with safe public defaults for the shared "Graysen Handoff Hub"
# project, so it works with no config. Set these only to point at a different one.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Quency AI proxy ---
# The chat talks to the built-in /api/chat serverless function by default.
# Override only if you host the proxy elsewhere (no trailing /chat).
VITE_AI_PROXY_URL=

# --- Server-side only (set in Vercel Project Settings, NOT committed) ---
# Required for Quency chat to actually respond. Never expose this in the browser.
# ANTHROPIC_API_KEY=sk-ant-...
