# Optional — the app ships with safe public defaults for the shared
# "Graysen Handoff Hub" Supabase project, so it works with no config.
# Set these only if you want to point the app at a different project.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional - for Quency AI chat (URL of your secure AI proxy exposing POST /chat)
VITE_AI_PROXY_URL=
